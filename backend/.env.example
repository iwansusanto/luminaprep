# Database Configuration
DATABASE_URL=mysql+mysqlconnector://username:password@localhost:3306/luminaprep
# For development, you can use: sqlite:///./luminaprep_dev.db

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8010/api/v1/auth/google/callback

# Application
APP_NAME=LuminaPrep Backend
APP_VERSION=0.1.0
DEBUG=false

# CORS
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
